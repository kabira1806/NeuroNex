# NeuroNex ElderlyCare API - Environment Variables Example
# Copy this file to .env and fill in the required values

# Database Configuration
# SQLite (default - works out of the box)
DATABASE_URL=sqlite+aiosqlite:///./data/neuronex.db

# PostgreSQL (optional - uncomment to use)
# DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/neuronex

# Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Application Settings
APP_NAME=NeuroNex API
DEBUG=true
